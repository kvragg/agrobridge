# =============================================================================
# AgroBridge — .env.local.example
# =============================================================================
# Copie para .env.local e preencha. NUNCA commitar .env.local.
# Variáveis prefixadas com NEXT_PUBLIC_* ficam expostas no bundle do client.
# Todas as outras só devem ser lidas em código server-side.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — autenticação, Postgres, Storage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# SERVER-ONLY — nunca importar em client component. Dá acesso total ao DB.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# -----------------------------------------------------------------------------
# URL pública do app
# -----------------------------------------------------------------------------
# Base canônica para emails transacionais, sitemap, redirects OAuth.
NEXT_PUBLIC_SITE_URL=https://agrobridge.space
# Fallback histórico usado em callbacks de signup/resend. Pode ser o mesmo
# valor de NEXT_PUBLIC_SITE_URL. Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Anthropic (Claude) — server-only
# -----------------------------------------------------------------------------
# Usado em entrevista (haiku), checklist (sonnet), dossiê (defesa),
# validação de documentos e análise de viabilidade.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Resend — email transacional (server-only)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Destino das notificações de novos leads/cadastros.
LEAD_NOTIFICATION_EMAIL=paulocosta.contato1@gmail.com
# Opcional. Se omitido, usa sandbox `onboarding@resend.dev`.
# Só preencha depois de verificar o domínio no painel Resend.
# RESEND_FROM_EMAIL=AgroBridge <noreply@agrobridge.space>

# -----------------------------------------------------------------------------
# Cakto — checkout externo + webhook de confirmação (server-only)
# -----------------------------------------------------------------------------
# Secret compartilhado usado para validar webhook:
#   - Cakto Pro: HMAC-SHA256 no header x-cakto-signature
#   - Cakto básico: campo `secret` dentro do payload JSON
CAKTO_WEBHOOK_SECRET=troque-por-secret-do-painel-cakto

# Product IDs criados no painel Cakto — o webhook mapeia id → tier.
# Preços comerciais: diagnostico=R$29,99 · dossie=R$297,99 · mentoria=R$697,99.
# Nomes comerciais na UI: Bronze / Prata / Ouro.
CAKTO_PRODUTO_DIAGNOSTICO=prd_xxxxxxxxxxxx
CAKTO_PRODUTO_DOSSIE=prd_xxxxxxxxxxxx
CAKTO_PRODUTO_MENTORIA=prd_xxxxxxxxxxxx

# Legacy — DossieCard.tsx usa enquanto migração para PlanosClient não termina.
# Deixar vazio se `/planos` for o único ponto de checkout.
# NEXT_PUBLIC_CAKTO_URL=https://pay.cakto.com.br/xxxxx

# -----------------------------------------------------------------------------
# Upstash Redis — rate limit distribuído (OPCIONAL)
# -----------------------------------------------------------------------------
# Sem estas vars, rotas caem para rate-limit in-memory (ok em dev/single-node,
# inconsistente entre múltiplas instâncias Vercel em produção).
# Pegue em https://console.upstash.com/ → Redis → seu database → REST API.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXXxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Sentry — observabilidade de erros em produção (OPCIONAL, ainda não plugado)
# -----------------------------------------------------------------------------
# `lib/logger.ts :: capturarErroProducao()` é o ponto único de integração.
# Quando for ativar, preencha DSN e adicione `Sentry.captureException` lá
# (TODO explícito no código). Sem DSN, erros só vão para console estruturado.
# SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzzz
